# Cosmos — environment variables
# Copy to .env.local and fill in values you have.
# Everything is optional: the app ships with safe fixture fallbacks.

# NASA APOD (https://api.nasa.gov) — "DEMO_KEY" works for light use.
NASA_API_KEY=DEMO_KEY

# Optional — pin a specific launch feed endpoint.
# Defaults to Launch Library 2 (LL2) public API.
LAUNCH_LIBRARY_BASE_URL=https://ll.thespacedevs.com/2.2.0

# Optional — space news feed (Spaceflight News API v4 is free/public).
SPACE_NEWS_BASE_URL=https://api.spaceflightnewsapi.net/v4

# Public site URL for metadata/OG tags (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://cosmos.example
